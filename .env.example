# ======================================
# HeadHunter API Configuration
# ======================================
# Получить токен: https://dev.hh.ru/admin
# Документация: https://github.com/hhru/api/blob/master/docs/general.md

# Required
HH_ACCESS_TOKEN=Bearer token for API requests
HH_CLIENT_ID=OAuth client ID from dev.hh.ru
HH_CLIENT_SECRET=OAuth client secret from dev.hh.ru

# Optional
HH_API_URL=https://api.hh.ru
HH_REQUEST_TIMEOUT=30  # seconds
HH_USER_AGENT=MyApp/1.0 (my@email.com)